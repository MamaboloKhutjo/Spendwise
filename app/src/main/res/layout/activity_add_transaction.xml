<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F2F2F2">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/header_bg_rounded"
        android:paddingStart="20dp"
        android:paddingTop="48dp"
        android:paddingEnd="20dp"
        android:paddingBottom="24dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_close"
            android:layout_centerVertical="true"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add Transaction"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_centerInParent="true"/>
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:background="@drawable/toggle_bg"
                android:layout_marginBottom="20dp">

                <Button
                    android:id="@+id/btnExpense"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="Expense"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:backgroundTint="#C62828"/>

                <Button
                    android:id="@+id/btnIncome"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="Income"
                    android:textColor="#888888"
                    android:backgroundTint="#2C2C2E"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Amount (R)"
                android:textColor="#888888"
                android:textSize="12sp"
                android:layout_marginBottom="4dp"/>
            <EditText
                android:id="@+id/etAmount"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:hint="0.00"
                android:textColor="#1C1C1E"
                android:textColorHint="#AAAAAA"
                android:textSize="24sp"
                android:textStyle="bold"
                android:inputType="numberDecimal"
                android:background="@drawable/input_bg_light"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Category"
                android:textColor="#888888"
                android:textSize="12sp"
                android:layout_marginBottom="4dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <Spinner
                    android:id="@+id/spinnerCategory"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:background="@drawable/input_bg_light"
                    android:paddingHorizontal="12dp"/>

                <ImageButton
                    android:id="@+id/btnAddCategory"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:src="@android:drawable/ic_input_add"
                    android:background="@drawable/input_bg_light"
                    android:layout_marginStart="8dp"
                    android:contentDescription="Add Category" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Date"
                android:textColor="#888888"
                android:textSize="12sp"
                android:layout_marginBottom="4dp"/>
            <TextView
                android:id="@+id/tvDate"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Select Date"
                android:gravity="center_vertical"
                android:textColor="#1C1C1E"
                android:background="@drawable/input_bg_light"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="16dp"
                android:clickable="true"
                android:focusable="true"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Start Time"
                        android:textColor="#888888"
                        android:textSize="12sp"
                        android:layout_marginBottom="4dp"/>
                    <TextView
                        android:id="@+id/tvStartTime"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="00:00"
                        android:gravity="center_vertical"
                        android:textColor="#1C1C1E"
                        android:background="@drawable/input_bg_light"
                        android:paddingHorizontal="16dp"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="End Time"
                        android:textColor="#888888"
                        android:textSize="12sp"
                        android:layout_marginBottom="4dp"/>
                    <TextView
                        android:id="@+id/tvEndTime"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="00:00"
                        android:gravity="center_vertical"
                        android:textColor="#1C1C1E"
                        android:background="@drawable/input_bg_light"
                        android:paddingHorizontal="16dp"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Description"
                android:textColor="#888888"
                android:textSize="12sp"
                android:layout_marginBottom="4dp"/>
            <EditText
                android:id="@+id/etNote"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:hint="e.g. Monthly salary, Woolworths..."
                android:textColor="#1C1C1E"
                android:textColorHint="#AAAAAA"
                android:inputType="textMultiLine"
                android:gravity="top"
                android:background="@drawable/input_bg_light"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Photograph (optional)"
                android:textColor="#888888"
                android:textSize="12sp"
                android:layout_marginBottom="4dp"/>
            <ImageView
                android:id="@+id/ivPhoto"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:scaleType="centerInside"
                android:background="@drawable/input_bg_light"
                android:src="@android:drawable/ic_menu_camera"
                android:layout_marginBottom="28dp"
                android:clickable="true"
                android:focusable="true"/>

            <Button
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Save Transaction"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:backgroundTint="#F5A623"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
