<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F2F2">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/bottomNav">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/header_bg_rounded" android:orientation="vertical" android:paddingStart="20dp" android:paddingTop="48dp" android:paddingEnd="20dp" android:paddingBottom="24dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="•••" android:textColor="#FFFFFF" android:textSize="20sp" android:layout_marginBottom="8dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Budget &amp; Goals" android:textColor="#FFFFFF" android:textSize="32sp" android:textStyle="bold"/>
            </LinearLayout>

            <!-- Monthly Budget & Goals -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="#FFFFFF"
                android:layout_margin="16dp"
                android:elevation="2dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tracking Setup"
                    android:textColor="#1C1C1E"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Monthly Budget (Initial Amount R)"
                    android:textColor="#888888"
                    android:textSize="12sp"/>
                <EditText
                    android:id="@+id/etMonthlyBudget"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:inputType="numberDecimal"
                    android:hint="e.g. 5000.00"
                    android:layout_marginBottom="16dp"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#EEEEEE"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Minimum Spending Goal (R)"
                    android:textColor="#888888"
                    android:textSize="12sp"/>
                <EditText
                    android:id="@+id/etMinGoal"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:inputType="numberDecimal"
                    android:hint="0.00"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Maximum Spending Goal (R)"
                    android:textColor="#888888"
                    android:textSize="12sp"/>
                <EditText
                    android:id="@+id/etMaxGoal"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:inputType="numberDecimal"
                    android:hint="0.00"
                    android:layout_marginBottom="12dp"/>

                <Button
                    android:id="@+id/btnSaveGoals"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Save Budget &amp; Goals"
                    android:backgroundTint="#2E7D32"
                    android:textColor="#FFFFFF"/>
            </LinearLayout>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Spending By Category" android:textColor="#1C1C1E" android:textSize="15sp" android:textStyle="bold" android:paddingHorizontal="16dp" android:paddingTop="8dp" android:paddingBottom="8dp"/>

            <!-- Period Selector -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/tvStartDate"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="@drawable/input_bg_light"
                    android:gravity="center"
                    android:text="Start Date"
                    android:layout_marginEnd="4dp"/>

                <TextView
                    android:id="@+id/tvEndDate"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:background="@drawable/input_bg_light"
                    android:gravity="center"
                    android:text="End Date"
                    android:layout_marginStart="4dp"/>
            </LinearLayout>

            <!-- Dynamic budget cards injected here -->
            <LinearLayout
                android:id="@+id/budgetCategoryContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"/>

            <Button
                android:id="@+id/btnAddBudget"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="20dp"
                android:text="Add Category Budget"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:backgroundTint="#F5A623"/>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Nav -->
    <LinearLayout android:id="@+id/bottomNav" android:layout_width="match_parent" android:layout_height="64dp" android:layout_alignParentBottom="true" android:background="#2C2C2E" android:orientation="horizontal">
        <LinearLayout android:id="@+id/navDashboard" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_dashboard" android:tint="#AAAAAA"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Dashboard" android:textColor="#AAAAAA" android:textSize="10sp" android:layout_marginTop="3dp"/>
        </LinearLayout>
        <LinearLayout android:id="@+id/navTransactions" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_wallet" android:tint="#AAAAAA"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Transactions" android:textColor="#AAAAAA" android:textSize="10sp" android:layout_marginTop="3dp"/>
        </LinearLayout>
        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center">
            <View android:layout_width="56dp" android:layout_height="56dp"/>
        </LinearLayout>
        <LinearLayout android:id="@+id/navBudget" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_budget" android:tint="#F5A623"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Budget" android:textColor="#F5A623" android:textSize="10sp" android:layout_marginTop="3dp"/>
        </LinearLayout>
        <LinearLayout android:id="@+id/navMe" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/ic_profile" android:tint="#AAAAAA"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Me" android:textColor="#AAAAAA" android:textSize="10sp" android:layout_marginTop="3dp"/>
        </LinearLayout>
    </LinearLayout>

    <ImageView android:id="@+id/fabAdd" android:layout_width="56dp" android:layout_height="56dp" android:layout_alignParentBottom="true" android:layout_centerHorizontal="true" android:layout_marginBottom="20dp" android:src="@drawable/ic_add" android:background="@drawable/fab_bg" android:padding="14dp" android:elevation="6dp"/>

</RelativeLayout>
