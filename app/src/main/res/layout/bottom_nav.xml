<?xml version="1.0" encoding="utf-8"?>
<!-- bottom_nav.xml — include this in each screen's root layout -->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="70dp"
    android:background="#2C2C2E">

    <!-- Nav Items -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:weightSum="4">

        <!-- Dashboard -->
        <LinearLayout
            android:id="@+id/navDashboard"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_dashboard"
                app:tint="#F5A623" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dashboard"
                android:textColor="#F5A623"
                android:textSize="10sp"
                android:layout_marginTop="3dp"/>
        </LinearLayout>

        <!-- Transactions -->
        <LinearLayout
            android:id="@+id/navTransactions"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_wallet"
                app:tint="#AAAAAA" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Transactions"
                android:textColor="#AAAAAA"
                android:textSize="10sp"
                android:layout_marginTop="3dp"/>
        </LinearLayout>

        <!-- Centre FAB placeholder (leave empty, FAB floats above) -->
        <View
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"/>

        <!-- Budget -->
        <LinearLayout
            android:id="@+id/navBudget"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_budget"
                app:tint="#AAAAAA" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Budget"
                android:textColor="#AAAAAA"
                android:textSize="10sp"
                android:layout_marginTop="3dp"/>
        </LinearLayout>

        <!-- Me (Profile) -->
        <LinearLayout
            android:id="@+id/navMe"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_profile"
                app:tint="#AAAAAA" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Me"
                android:textColor="#AAAAAA"
                android:textSize="10sp"
                android:layout_marginTop="3dp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Centre FAB (+) button — floats above nav bar -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAdd"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_alignParentTop="true"
        android:layout_marginTop="-24dp"
        android:src="@drawable/ic_add"
        app:backgroundTint="#F5A623"
        app:tint="#FFFFFF"
        app:elevation="6dp"
        xmlns:app="http://schemas.android.com/apk/res-auto"/>

</RelativeLayout>
